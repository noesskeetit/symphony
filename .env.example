# Linear API key (Settings -> Security & access -> Personal API keys)
LINEAR_API_KEY=lin_api_xxx

# Linear project / team
LINEAR_PROJECT_ID=
LINEAR_TEAM_KEY=
LINEAR_DONE_STATE_ID=

# GitHub repo (owner/name)
GITHUB_REPO=owner/repo

# Telegram bot (create via @BotFather)
TG_BOT_TOKEN=
TG_CHAT_ID=

# OpenRouter (optional, for alternative models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
